# RunPod API key (from https://www.runpod.io/console/user/settings)
RUNPOD_API_KEY=your_runpod_api_key

# S3-compatible bucket credentials (Cloudflare R2, AWS S3, etc.)
BUCKET_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
BUCKET_ACCESS_KEY_ID=your_access_key
BUCKET_ACCESS_KEY_SECRET=your_secret_key
BUCKET_NAME=your-bucket-name
